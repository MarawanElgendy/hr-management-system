@model List<HRMS.Models.LeaveRequest>
@{
    ViewData["Title"] = "Team Leave Requests";
}

<div class="container mt-4">
    <h1 class="mb-4 fw-light">Review Requests</h1>
    <p class="text-muted mb-4">Approve or reject leave applications from your team.</p>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <p class="text-muted mb-0">No pending leave requests from your team.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Dates</th>
                            <th>Duration</th>
                            <th>Type</th>
                            <th>Justification</th>
                            <th>Attachment</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model)
                        {
                            <tr>
                                <td class="fw-bold">
                                    @request.Employee?.FirstName @request.Employee?.LastName
                                    @if(request.Employee != null && request.Employee.IsFlagged)
                                    {
                                        <span class="text-muted" title="Flagged">⚠️</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var endDate = request.StartDate.AddDays(request.Duration - 1);
                                    }
                                    @request.StartDate.ToString("d") - @endDate.ToString("d")
                                </td>
                                <td>@request.Duration Days</td>
                                <td>
                                    <span class="badge bg-dark">@request.LeaveType?.TypeName</span>
                                </td>
                                <td class="small">@request.Justification</td>
                                <td>
                                    @if(request.LeaveDocuments != null && request.LeaveDocuments.Any())
                                    {
                                         var doc = request.LeaveDocuments.First();
                                         <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-dark">View</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <form asp-action="ApproveLeave" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@request.LeaveRequestId" />
                                            <button type="submit" class="btn btn-sm btn-dark" onclick="return confirm('Approve this request?')">Approve</button>
                                        </form>
                                        <form asp-action="RejectLeave" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@request.LeaveRequestId" />
                                            <button type="submit" class="btn btn-sm btn-outline-dark" onclick="return confirm('Reject this request?')">Reject</button>
                                        </form>
                                        <form asp-action="ToggleEmployeeFlag" method="post" class="d-inline">
                                            <input type="hidden" name="employeeId" value="@request.EmployeeId" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning" title="Flag/Unflag Employee for Irregular Leaves">
                                                @(request.Employee != null && request.Employee.IsFlagged ? "Unflag" : "Flag")
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
