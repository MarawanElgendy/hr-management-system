@{
    ViewData["Title"] = "Assign Team Shift";
}

<div class="container mt-4">
    <h1 class="mb-4 fw-light">Team Scheduling</h1>
    <p class="text-muted mb-4">Assign and manage shifts for your direct reports.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-action="AssignTeamShift" method="post">
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label small text-muted">Start Date</label>
                        <input type="date" name="startDate" class="form-control" required />
                    </div>
                    <div class="col">
                        <label class="form-label small text-muted">End Date</label>
                        <input type="date" name="endDate" class="form-control" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small text-muted">Shift Name</label>
                    <select name="shiftType" class="form-select" required>
                        <option value="">Select Scheduled Shift</option>
                        @if (ViewBag.ShiftNames != null)
                        {
                            @foreach (var name in ViewBag.ShiftNames)
                            {
                                <option value="@name">@name</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label small text-muted">Team Member</label>
                    <select name="employeeID" class="form-select" required>
                        <option value="">Select Employee</option>
                        @if (ViewBag.TeamMembers != null)
                        {
                            @foreach (var emp in ViewBag.TeamMembers)
                            {
                                <option value="@emp.EmployeeID">@emp.FullName (@emp.PositionTitle)</option>
                            }
                        }
                    </select>
                </div>

                <button type="submit" class="btn btn-dark">Assign Shift</button>
            </form>
        </div>
    </div>
</div>
