@using DTOs
@model EmployeeFullProfileDTO

@{
    var userIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    int.TryParse(userIdStr, out int currentUserId);
    bool isSelf = currentUserId == Model.EmployeeID;
}

<div class="container mt-4">
    <h1 class="mb-4 fw-light">@Model.FullName</h1>
    <p class="text-muted mb-4">Employee Profile</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-bold">Personal Information</h5>
        </div>
        <ul class="list-group list-group-flush">
            @RenderRow("Full Name", Model.FullName)
            @RenderRow("Employee ID", Model.EmployeeID.ToString())
            @RenderEditableRow("Email Address", "emailAddress", Model.EmailAddress, isSelf)
            @RenderEditableRow("Phone Number", "phoneNumber", Model.PhoneNumber, isSelf)
            @RenderEditableRow("Address", "address", Model.Address, isSelf)
            @RenderEditableRow("Biography", "biography", Model.Biography, isSelf)
            @RenderRow("National ID", Model.NationalID)
            @RenderRow("Birth Date", Model.BirthDate?.ToShortDateString())
            @RenderRow("Birth Country", Model.BirthCountry)
        </ul>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-bold">Emergency Contact</h5>
        </div>
        <ul class="list-group list-group-flush">
            @RenderEditableRow("Contact Name", "emergencyContactName", Model.EmergencyContactName, isSelf)
            @RenderEditableRow("Contact Phone", "emergencyContactPhone", Model.EmergencyContactPhone, isSelf)
            @RenderEditableRow("Relationship", "relationship", Model.Relationship, isSelf)
        </ul>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-bold">Employment Details</h5>
        </div>
        <ul class="list-group list-group-flush">
            @RenderRow("Department", Model.DepartmentName)
            @RenderRow("Position", Model.PositionTitle)
            @RenderRow("Manager", Model.ManagerName)
            @RenderRow("Employment Status", Model.EmploymentStatus)
            @RenderRow("Hire Date", Model.HireDate?.ToShortDateString())
            @RenderRow("Contract Type", Model.ContractType)
            @RenderRow("Contract Start", Model.ContractStart?.ToShortDateString())
            @RenderRow("Contract End", Model.ContractEnd?.ToShortDateString())
            @RenderRow("Pay Grade", Model.PayGrade)
        </ul>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-bold">Skills</h5>
        </div>
        <div class="card-body">
            @if (Model.Skills != null && Model.Skills.Any())
            {
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Skill Name</th>
                            <th>Proficiency</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var skill in Model.Skills)
                        {
                            <tr>
                                <td>@skill.SkillName</td>
                                <td>@skill.ProficiencyLevel</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">No skills recorded.</p>
            }
        </div>
    </div>
</div>

@functions {
    public Microsoft.AspNetCore.Html.IHtmlContent RenderRow(string label, string? value)
    {
        value ??= "N/A";
        var html = $"<li class='list-group-item d-flex justify-content-between align-items-center'><span class='text-muted'>{label}</span><span>{value}</span></li>";
        return new Microsoft.AspNetCore.Html.HtmlString(html);
    }

    public Microsoft.AspNetCore.Html.IHtmlContent RenderEditableRow(string label, string fieldName, string? value, bool isEditable)
    {
        value ??= "";
        var html = "<li class='list-group-item'><div class='row align-items-center'>";
        html += $"<div class='col-md-3'><span class='text-muted'>{label}</span></div>";

        if (isEditable)
        {
            html += $"<div class='col-md-9'><form method='post' action='/Employee/UpdatePersonalDetails' class='input-group input-group-sm'>";
            html += $"<input type='hidden' name='employeeID' value='{Model.EmployeeID}' />";
            html += $"<input type='hidden' name='field' value='{fieldName}' />";
            html += $"<input type='text' name='value' class='form-control' value='{value}' />";
            html += $"<button type='submit' class='btn btn-outline-dark'>Update</button>";
            html += "</form></div>";
        }
        else
        {
            html += $"<div class='col-md-9'>{value}</div>";
        }

        html += "</div></li>";
        return new Microsoft.AspNetCore.Html.HtmlString(html);
    }
}