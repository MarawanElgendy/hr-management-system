@model List<HRMS.Models.Attendance>
@{
    ViewData["Title"] = "My Attendance";
    var lastRecord = Model.FirstOrDefault();
    bool isCheckedIn = lastRecord != null && lastRecord.ExitTime == null && lastRecord.EntryTime.HasValue && lastRecord.EntryTime.Value.Date == DateTime.Today;
}

<div class="container mt-4">
    <h1 class="mb-4 fw-light">Attendance</h1>
    <p class="text-muted mb-4">Track your daily check-ins and check-outs.</p>

    <div class="row mb-5">
        <div class="col-md-12 text-center">
            <div class="card shadow-sm border-0 p-4 d-inline-block">
                <h5 class="mb-3 fw-bold">
                    Status:
                    @if (isCheckedIn)
                    {
                        <span class="fw-normal">Checked In</span>
                    }
                    else
                    {
                        <span class="fw-normal text-muted">Checked Out</span>
                    }
                </h5>

                @if (isCheckedIn)
                {
                    <p class="text-muted small">You checked in at @lastRecord?.EntryTime?.ToShortTimeString()</p>
                    <form asp-action="CheckOut" method="post">
                        <button type="submit" class="btn btn-dark btn-lg px-5">Check Out</button>
                    </form>
                }
                else
                {
                    <p class="text-muted small">Ready to start?</p>
                    <form asp-action="CheckIn" method="post">
                        <button type="submit" class="btn btn-outline-dark btn-lg px-5">Check In</button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-bold">Recent Activity</h5>
        </div>
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Scan In</th>
                        <th>Scan Out</th>
                        <th>Duration</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.EntryTime?.ToString("d")</td>
                            <td>@item.EntryTime?.ToShortTimeString()</td>
                            <td>
                                @if (item.ExitTime.HasValue)
                                {
                                    @item.ExitTime.Value.ToShortTimeString()
                                }
                                else
                                {
                                    <span class="badge bg-dark">Active</span>
                                }
                            </td>
                            <td>
                                @if (item.ExitTime.HasValue)
                                {
                                    @((item.ExitTime.Value - item.EntryTime.Value).ToString(@"hh\:mm"))
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="offline-indicator" class="alert alert-warning fixed-bottom m-3" style="display:none; width: auto; max-width: 300px;">
    <strong>Offline Mode</strong><br/>
    Attendance will be saved locally and synced when online.
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const forms = document.querySelectorAll('form[action*="CheckIn"], form[action*="CheckOut"]');
            const offlineIndicator = document.getElementById('offline-indicator');

            function updateOnlineStatus() {
                if (navigator.onLine) {
                    offlineIndicator.style.display = 'none';
                    syncLogs();
                } else {
                    offlineIndicator.style.display = 'block';
                }
            }

            window.addEventListener('online', updateOnlineStatus);
            window.addEventListener('offline', updateOnlineStatus);
            updateOnlineStatus();

            forms.forEach(form => {
                form.addEventListener('submit', function (e) {
                    if (!navigator.onLine) {
                        e.preventDefault();
                        const isCheckIn = form.getAttribute('action').includes('CheckIn');
                        const type = isCheckIn ? 'CheckIn' : 'CheckOut';
                        const log = { Timestamp: new Date().toISOString(), Type: type };
                        saveLog(log);
                        alert('You are offline. ' + type + ' saved locally and will sync when reconnected.');
                    }
                });
            });

            function saveLog(log) {
                let logs = JSON.parse(localStorage.getItem('attendance_logs') || '[]');
                logs.push(log);
                localStorage.setItem('attendance_logs', JSON.stringify(logs));
            }

            function syncLogs() {
                let logs = JSON.parse(localStorage.getItem('attendance_logs') || '[]');
                if (logs.length === 0) return;
                fetch('/Employee/SyncOfflineLogs', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(logs)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        localStorage.removeItem('attendance_logs');
                        location.reload();
                    }
                })
                .catch(err => console.error('Sync error:', err));
            }
        });
    </script>
}
