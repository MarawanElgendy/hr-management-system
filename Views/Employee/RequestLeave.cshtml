@{
    ViewData["Title"] = "Request Leave";
}

<div class="container mt-4">
    <h1 class="mb-4 fw-light">Leave Request</h1>
    <p class="text-muted mb-4">Apply for annual, sick, or other types of leave.</p>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <form asp-action="RequestLeave" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label small text-muted">Leave Type</label>
                            <select name="leaveTypeId" class="form-select" required>
                                <option value="">-- Select Type --</option>
                                @if (ViewBag.LeaveTypes != null)
                                {
                                    @foreach (var type in ViewBag.LeaveTypes)
                                    {
                                        <option value="@type.LeaveTypeId">@type.TypeName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label small text-muted">Start Date</label>
                                <input type="date" name="startDate" class="form-control" required />
                            </div>
                            <div class="col">
                                <label class="form-label small text-muted">End Date</label>
                                <input type="date" name="endDate" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">Justification</label>
                            <textarea name="justification" class="form-control" rows="4" required placeholder="Reason for leave..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small text-muted">Attachment (Optional)</label>
                            <input type="file" name="attachment" class="form-control" />
                            <div class="form-text">Upload medical certificates or other supporting documents.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-dark btn-lg">Submit Request</button>
                            <a asp-controller="Home" asp-action="Leave" class="btn btn-outline-dark">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
