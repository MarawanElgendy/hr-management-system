@model List<HRMS.Models.LeavePolicy>
@{
    ViewData["Title"] = "Manage Leave Policies";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-light mb-1">Leave Policies</h1>
            <p class="text-muted mb-0">Configure organizational leave policies.</p>
        </div>
        <a asp-action="EditLeavePolicy" class="btn btn-dark">Add New Policy</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Policy Name</th>
                            <th>Purpose</th>
                            <th>Notice Period</th>
                            <th>Resets Yearly</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Name</td>
                                <td class="text-muted small">@item.Purpose</td>
                                <td>@item.NoticePeriod days</td>
                                <td>
                                    @if(item.ResetOnNewYear == true)
                                    {
                                        <span class="badge bg-dark">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">No</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="EditLeavePolicy" asp-route-id="@item.LeavePolicyId" class="btn btn-sm btn-outline-dark">Edit</a>
                                        <form asp-action="DeleteLeavePolicy" asp-route-id="@item.LeavePolicyId" method="post" onsubmit="return confirm('Delete this policy?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-dark">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
