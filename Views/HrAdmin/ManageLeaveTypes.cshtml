@model List<HRMS.Models.LeaveType>
@{
    ViewData["Title"] = "Manage Leave Types";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-light mb-1">Leave Types</h1>
            <p class="text-muted mb-0">Define categories of leave available to employees.</p>
        </div>
        <a asp-action="EditLeaveType" class="btn btn-dark">Add New Type</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.TypeName</td>
                                <td class="text-muted small">@item.Description</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="EditLeaveType" asp-route-id="@item.LeaveTypeId" class="btn btn-sm btn-outline-dark">Edit</a>
                                        <form asp-action="DeleteLeaveType" asp-route-id="@item.LeaveTypeId" method="post" onsubmit="return confirm('Delete this leave type?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-dark">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
