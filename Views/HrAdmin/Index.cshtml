@{
    ViewData["Title"] = "HR Admin Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-4 fw-light">HR Administration</h1>
    <p class="text-muted mb-4">Manage employee profiles and data.</p>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 fw-bold">Find Employee</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="FindEmployee">
                        <div class="mb-3">
                            <label for="id" class="form-label small text-muted">Employee ID</label>
                            <input type="number" class="form-control" id="id" name="id" required placeholder="Enter Employee ID">
                        </div>
                        <button type="submit" class="btn btn-dark w-100">Edit Profile</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
