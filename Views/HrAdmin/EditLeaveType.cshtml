@model HRMS.Models.LeaveType
@{
    ViewData["Title"] = Model.LeaveTypeId == 0 ? "Create Leave Type" : "Edit Leave Type";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-light mb-1">@ViewData["Title"]</h1>
            <p class="text-muted mb-0">Define a new category of leave.</p>
        </div>
        <a asp-action="ManageLeaveTypes" class="btn btn-outline-dark">Back</a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <form asp-action="EditLeaveType" method="post">
                        <input type="hidden" asp-for="LeaveTypeId" />
                        
                        <div class="mb-3">
                            <label asp-for="TypeName" class="form-label small text-muted">Type Name</label>
                            <input asp-for="TypeName" class="form-control" required placeholder="e.g. Sick Leave" />
                            <span asp-validation-for="TypeName" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label small text-muted">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description of the leave type..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-dark btn-lg">Save Leave Type</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
