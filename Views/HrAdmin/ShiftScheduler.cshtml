@{
    ViewData["Title"] = "Shift Scheduler";
}

<div class="container mt-4">
    <h1 class="mb-4 fw-light">Shift Scheduler</h1>
    <p class="text-muted mb-4">Generate schedule entries for Split or Rotational shifts.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <ul class="nav nav-tabs mb-4" id="shiftTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="split-tab" data-bs-toggle="tab" data-bs-target="#split" type="button" role="tab">Split Shift</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="rotational-tab" data-bs-toggle="tab" data-bs-target="#rotational" type="button" role="tab">Rotational Shift</button>
        </li>
    </ul>

    <div class="tab-content" id="shiftTabContent">
        @* Split Shift Tab *@
        <div class="tab-pane fade show active" id="split" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <form asp-action="GenerateSplitSchedule" method="post">
                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label small text-muted">Start Date</label>
                                <input type="date" name="startDate" class="form-control" required />
                            </div>
                            <div class="col">
                                <label class="form-label small text-muted">End Date</label>
                                <input type="date" name="endDate" class="form-control" required />
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h6 class="fw-bold">Shift Block 1</h6>
                                <div class="input-group mb-2">
                                    <span class="input-group-text">Start</span>
                                    <input type="time" name="start1" class="form-control" required />
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text">End</span>
                                    <input type="time" name="end1" class="form-control" required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-bold">Shift Block 2</h6>
                                <div class="input-group mb-2">
                                    <span class="input-group-text">Start</span>
                                    <input type="time" name="start2" class="form-control" required />
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text">End</span>
                                    <input type="time" name="end2" class="form-control" required />
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-dark">Generate Split Schedule</button>
                    </form>
                </div>
            </div>
        </div>

        @* Rotational Shift Tab *@
        <div class="tab-pane fade" id="rotational" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <form asp-action="GenerateRotationalSchedule" method="post">
                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label small text-muted">Start Date</label>
                                <input type="date" name="startDate" class="form-control" required />
                            </div>
                            <div class="col">
                                <label class="form-label small text-muted">End Date</label>
                                <input type="date" name="endDate" class="form-control" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">Rotation Cycle (Days per shift type)</label>
                            <input type="number" name="cycleLengthDays" class="form-control" value="2" min="1" required />
                            <div class="form-text">e.g., 2 means: 2 Days Morning -> 2 Days Night -> 2 Days Off -> Repeat</div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label small text-muted">Cycle Pattern</label>
                            <input type="text" class="form-control" value="Morning, Night, Off" readonly disabled />
                            <div class="form-text">Currently hardcoded. Future versions will allow custom patterns.</div>
                        </div>
                        <button type="submit" class="btn btn-dark">Generate Rotational Schedule</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
